// Prisma schema for SportsForAll
// Tài liệu yêu cầu: ../../../Idea.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  business
  admin
}

enum Sport {
  football
  basketball
  badminton
  volleyball
  tennis
}

enum SkillLevel {
  beginner
  amateur
  intermediate
  advanced
  pro
}

enum TeamRole {
  captain
  co_captain
  member
}

enum RecruitmentStatus {
  open
  closed
}

enum JoinRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

enum MatchRequestStatus {
  open
  matched
  cancelled
  expired
}

enum ChallengeStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum MatchStatus {
  scheduled
  completed
  cancelled
}

enum NotificationType {
  join_request_received
  join_request_accepted
  join_request_rejected
  challenge_received
  challenge_accepted
  challenge_rejected
  match_scheduled
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  displayName   String
  avatarUrl     String?
  bio           String?
  birthYear     Int?
  region        String?
  role          UserRole   @default(user)
  reputation    Float      @default(0)
  emailVerified Boolean    @default(false)
  onboardedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  refreshTokens     RefreshToken[]
  sportPreferences  SportPreference[]
  teamMemberships   TeamMember[]
  joinRequests      JoinRequest[]
  notifications     Notification[]

  @@index([region])
}

model SportPreference {
  id          String      @id @default(cuid())
  userId      String
  sport       Sport
  skillLevel  SkillLevel
  position    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport])
  @@index([sport, skillLevel])
}

model Team {
  id          String      @id @default(cuid())
  name        String
  sport       Sport
  region      String?
  description String?
  logoUrl     String?
  skillLevel  SkillLevel?
  reputation  Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members          TeamMember[]
  recruitmentPosts RecruitmentPost[]
  matchRequests    MatchRequest[]
  challenges       Challenge[]
  matchesAsHome    Match[]           @relation("HomeTeam")
  matchesAsAway    Match[]           @relation("AwayTeam")

  @@index([sport, region])
  @@index([sport, skillLevel])
}

model RecruitmentPost {
  id             String            @id @default(cuid())
  teamId         String
  sport          Sport
  region         String?
  positionNeeded String?
  skillLevelMin  SkillLevel?
  description    String
  status         RecruitmentStatus @default(open)
  expiresAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  team     Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requests JoinRequest[]

  @@index([sport, region, status])
  @@index([teamId, status])
  @@index([status, createdAt])
}

model JoinRequest {
  id         String            @id @default(cuid())
  postId     String
  userId     String
  status     JoinRequestStatus @default(pending)
  message    String?
  createdAt  DateTime          @default(now())
  decidedAt  DateTime?

  post RecruitmentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, status])
}

model MatchRequest {
  id            String             @id @default(cuid())
  teamId        String
  sport         Sport
  region        String?
  preferredTime DateTime?
  venueName     String?
  description   String
  status        MatchRequestStatus @default(open)
  skillLevelMin SkillLevel?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  team       Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  challenges Challenge[]
  match      Match?

  @@index([sport, region, status])
  @@index([teamId, status])
  @@index([status, createdAt])
}

model Challenge {
  id               String          @id @default(cuid())
  matchRequestId   String
  challengerTeamId String
  message          String?
  status           ChallengeStatus @default(pending)
  createdAt        DateTime        @default(now())
  decidedAt        DateTime?

  matchRequest    MatchRequest @relation(fields: [matchRequestId], references: [id], onDelete: Cascade)
  challengerTeam  Team         @relation(fields: [challengerTeamId], references: [id], onDelete: Cascade)

  @@unique([matchRequestId, challengerTeamId])
  @@index([challengerTeamId, status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Match {
  id              String      @id @default(cuid())
  matchRequestId  String?     @unique
  homeTeamId      String
  awayTeamId      String
  sport           Sport
  scheduledAt     DateTime?
  venueName       String?
  status          MatchStatus @default(scheduled)
  homeScore       Int?
  awayScore       Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  matchRequest MatchRequest? @relation(fields: [matchRequestId], references: [id], onDelete: SetNull)
  homeTeam     Team          @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam     Team          @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  @@index([homeTeamId, status])
  @@index([awayTeamId, status])
  @@index([sport, scheduledAt])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(member)
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
